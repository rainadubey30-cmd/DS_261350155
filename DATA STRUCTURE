"""
Program 2:
Concatenate three dictionaries
to create a new dictionary.
"""

# Creating sample dictionaries
dic1 = {1: 10, 2: 20}
dic2 = {3: 30, 4: 40}
dic3 = {5: 50, 6: 60}

