Program 1.  Read the entire content from a text file and display it

file = open("sample.txt", "r")
content = file.read()
print(content)
file.close()


program 2. Read first n lines from a text file (n as user input)

n = int(input("Enter the number of lines: "))

file = open("sample.txt", "r")

for i in range(n):
    line = file.readline()
    if not line:
        break
    print(line, end="")

file.close()


program 3. Accept input from user and append it to a text file

text = input("Enter text to append: ")

file = open("sample.txt", "a")
file.write(text + "\n")
file.close()

print("Text appended successfully.")

program 4. Read contents line by line and store each line into a list


file = open("sample.txt", "r")

lines = []

for line in file:
    lines.append(line.strip())

file.close()

print("List of lines:")
print(lines)


program 5. Find the longest word from the text file

file = open("sample.txt", "r")

text = file.read()
file.close()

words = text.split()

longest = words[0]

for word in words:
    if len(word) > len(longest):
        longest = word

print("Longest word:", longest)


programm 6. Count the frequency of a user-entered word in a text file

word = input("Enter the word to search: ")

file = open("sample.txt", "r")

text = file.read()
file.close()

words = text.split()

count = words.count(word)

print("Frequency of", word, "is", count)
