"""
Program 6:
Write a program to check whether
a given number is Prime or Not.
"""

# Taking input
num = int(input("Enter a number: "))

# Numbers less than 2 are not prime
if num < 2:
    print("Not Prime")
else:
    is_prime = True

    # Check divisibility
    for i in range(2, int(num ** 0.5) + 1):

        if num % i == 0:
            is_prime = False
            break

    if is_prime:
        print("Prime")
    else:
        print("Not Prime")



"""
Program 7:
Print all prime numbers between 10 and 99.
"""

# Loop through numbers from 10 to 99
for num in range(10, 100):

    is_prime = True

    # Check if current number is prime
    for i in range(2, int(num ** 0.5) + 1):

        if num % i == 0:
            is_prime = False
            break

    if is_prime:
        print(num)



"""
Program 8:
Find the sum of all digits
of a g"iven number.
"""

# Taking input
num = int(input("Enter a number: "))

sum_digits = 0

# Calculate sum of digits
while num > 0:

    digit = num % 10
    sum_digits += digit
    num //= 10

print("Sum of digits =", sum_digits)



